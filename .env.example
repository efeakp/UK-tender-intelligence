# ── Server ────────────────────────────────────────────────────────────────────
APP_ENV=development            # development | production
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_TTL_MINUTES=60

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Cron expression for automatic daily refresh (default: 7:00 AM UTC)
REFRESH_CRON=0 7 * * *

# ── Scoring ───────────────────────────────────────────────────────────────────
MIN_SCORE_DEFAULT=3            # Tenders below this score are excluded by default

# ── Find a Tender ─────────────────────────────────────────────────────────────
FAT_BASE_URL=https://www.find-tender.service.gov.uk/api/1.0/ocdsReleasePackages
FAT_PAGE_SIZE=50
# FAT_API_KEY=                 # Optional — FaT is open but key raises rate limits

# ── Contracts Finder (OCDS Search endpoint — per official CF OCDS guide v2.1) ─
CF_BASE_URL=https://www.contractsfinder.service.gov.uk/Published/Notices/OCDS/Search
CF_PAGE_SIZE=100
